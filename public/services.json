[
  {
    "key": "lotus-light",
    "name": "Lotus Light Link",
    "repo": "https://github.com/raagerrd-ship-it/lotus-light-link.git",
    "releaseUrl": "https://api.github.com/repos/raagerrd-ship-it/lotus-light-link/releases/latest",
    "releaseAsset": "dist.tar.gz",
    "installDir": "/opt/lotus-light",
    "runInstallOnRelease": false,
    "installScript": "scripts/install.sh",
    "updateScript": "/opt/lotus-light/scripts/update.sh",
    "uninstallScript": "scripts/uninstall.sh",
    "components": {
      "engine": {
        "type": "node",
        "entrypoint": "pi/dist/index.js",
        "service": "lotus-light-engine",
        "alwaysOn": true
      },
      "ui": {
        "type": "static",
        "entrypoint": "dist/",
        "service": "lotus-light-ui",
        "alwaysOn": false
      }
    }
  },
  {
