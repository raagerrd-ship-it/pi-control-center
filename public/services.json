[
  {
    "key": "lotus-light",
    "name": "Lotus Light Link",
    "repo": "https://github.com/raagerrd-ship-it/lotus-light-link.git",
    "releaseUrl": "https://api.github.com/repos/raagerrd-ship-it/lotus-light-link/releases/latest",
    "installDir": "/opt/lotus-light",
    "installScript": "pi/setup-lotus.sh",
    "updateScript": "/opt/lotus-light/pi/update-services.sh",
    "uninstallScript": "pi/uninstall-lotus.sh",
    "components": {
      "engine": {
        "type": "node",
        "entrypoint": "pi/start-lotus.js",
        "service": "lotus-light-engine",
        "alwaysOn": true
      },
      "ui": {
        "type": "static",
        "entrypoint": "dist/",
        "service": "lotus-light-ui",
        "alwaysOn": false
      }
    }
  },
  {
    "key": "cast-away",
    "name": "Cast Away Web",
    "type": "node",
    "entrypoint": "bridge-pi/index.js",
    "repo": "https://github.com/raagerrd-ship-it/hromecast.git",
    "releaseUrl": "https://api.github.com/repos/raagerrd-ship-it/hromecast/releases/latest",
    "installDir": "$HOME/.local/share/cast-away",
    "installScript": "bridge-pi/install-linux.sh",
    "updateScript": "$HOME/.local/share/cast-away/bridge-pi/update.sh",
    "uninstallScript": "bridge-pi/uninstall-linux.sh",
    "service": "cast-away"
  },
  {
    "key": "sonos-gateway",
    "name": "Sonos Gateway",
    "type": "node",
    "entrypoint": "bridge/index.js",
    "repo": "https://github.com/raagerrd-ship-it/sonos-gateway.git",
    "releaseUrl": "https://api.github.com/repos/raagerrd-ship-it/sonos-gateway/releases/latest",
    "installDir": "$HOME/.local/share/sonos-proxy",
    "installScript": "bridge/install-linux.sh",
    "updateScript": "$HOME/.local/share/sonos-proxy/bridge/update.sh",
    "uninstallScript": "bridge/uninstall-linux.sh",
    "service": "sonos-proxy"
  }
]
